<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vibe Prompter</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <!-- Babel for in-browser JSX compilation -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        body { margin: 0; background-color: #030712; } /* gray-950 */
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef, useMemo } = React;

        // אייקונים
        const IconSettings = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="text-blue-500"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>;
        const IconPlay = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>;
        const IconStop = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>;
        const IconMic = () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>;
        const IconMicOff = () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="2" y1="2" x2="22" y2="22"></line><path d="M18.89 13.23A7.12 7.12 0 0 0 19 12v-2"></path><path d="M5 10v2a7 7 0 0 0 12 5"></path><path d="M15 9.34V5a3 3 0 0 0-5.68-1.33"></path><path d="M9 9v3a3 3 0 0 0 5.12 2.12"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>;
        const IconGlobe = () => <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>;

        function App() {
            const [text, setText] = useState('Welcome to the deep dive on how we are replacing legacy LMS systems with custom code. \nבסרטון הזה נדבר על הכלים שמאפשרים לנו לעשות את זה, \nLike Cursor and Notebook LM.');
            const [fontSize, setFontSize] = useState(48);
            const [alignment, setAlignment] = useState('center');
            const [padding, setPadding] = useState(10);
            const [isPlaying, setIsPlaying] = useState(false);
            const [isListening, setIsListening] = useState(false);
            const [currentWordIndex, setCurrentWordIndex] = useState(0);
            const [mirrorMode, setMirrorMode] = useState(false);
            const [flipVertical, setFlipVertical] = useState(false);
            const [supportError, setSupportError] = useState('');
            
            const containerRef = useRef(null);
            const recognitionRef = useRef(null);
            const wordsRef = useRef([]);
            const lastSpeechRef = useRef('');

            // אלגוריתם זיהוי שפה
            const detectedLang = useMemo(() => {
                const hebrewChars = (text.match(/[א-ת]/g) || []).length;
                const englishChars = (text.match(/[a-zA-Z]/g) || []).length;
                return hebrewChars >= englishChars ? 'he' : 'en';
            }, [text]);

            const words = text.split(/(\s+)/).filter(w => w.trim().length > 0 || w === '\n');
            wordsRef.current = words;

            // ניקוי מילים כולל המרה לאותיות קטנות (קריטי באנגלית)
            const cleanWord = (word) => {
                if (!word) return '';
                // שומר רק אותיות בעברית, אנגלית ומספרים. הופך לאותיות קטנות למניעת בעיות Case.
                return word.replace(/[^א-תa-zA-Z0-9]/g, '').toLowerCase().trim();
            };

            const isFuzzyMatch = (w1, w2) => {
                if (!w1 || !w2) return false;
                if (w1 === w2) return true; // תופס מילים קצרות במדויק (is, a, the, של, על)
                
                // עבור מילים ארוכות מ-3 אותיות, נאפשר חיתוך גמיש 
                if (w1.length >= 4 && w2.length >= 4) {
                    if (w1.includes(w2) || w2.includes(w1)) return true;
                }
                return false;
            };

            useEffect(() => {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) {
                    setSupportError('הדפדפן לא תומך בזיהוי דיבור. השתמש ב-Chrome או Safari.');
                    return;
                }

                const recognition = new SpeechRecognition();
                // הגדרת השפה דינמית לפי זיהוי הטקסט
                recognition.lang = detectedLang === 'he' ? 'he-IL' : 'en-US';
                recognition.continuous = true;
                recognition.interimResults = true;

                recognition.onstart = () => setIsListening(true);
                recognition.onerror = (event) => {
                    console.error('Speech error:', event.error);
                    if (event.error !== 'no-speech') setIsListening(false);
                };
                recognition.onend = () => {
                    setIsListening(false);
                    if (isPlaying) {
                        try { setTimeout(() => recognition.start(), 300); } catch (e) {}
                    }
                };

                recognition.onresult = (event) => {
                    let interimTranscript = '';
                    let finalTranscript = '';

                    for (let i = event.resultIndex; i < event.results.length; ++i) {
                        if (event.results[i].isFinal) {
                            finalTranscript += event.results[i][0].transcript;
                        } else {
                            interimTranscript += event.results[i][0].transcript;
                        }
                    }

                    const latestSpeech = (finalTranscript + ' ' + interimTranscript).trim();
                    if (!latestSpeech || latestSpeech === lastSpeechRef.current) return;
                    lastSpeechRef.current = latestSpeech;

                    const spokenWords = latestSpeech.split(/\s+/).map(cleanWord).filter(w => w.length > 0);
                    if (spokenWords.length === 0) return;

                    const searchWindow = 12; 
                    const wordsToCheck = spokenWords.slice(-4); 

                    setCurrentWordIndex((currentIndex) => {
                        let bestJump = currentIndex;
                        
                        for (let i = currentIndex; i < Math.min(currentIndex + searchWindow, wordsRef.current.length); i++) {
                            const targetWord = cleanWord(wordsRef.current[i]);
                            
                            let matchIndexInSpoken = -1;
                            for (let j = wordsToCheck.length - 1; j >= 0; j--) {
                                if (isFuzzyMatch(targetWord, wordsToCheck[j])) {
                                    matchIndexInSpoken = j;
                                    break;
                                }
                            }

                            if (matchIndexInSpoken !== -1) {
                                const jumpDistance = i - currentIndex;
                                
                                // Context Lock
                                if (jumpDistance > 2) {
                                    if (matchIndexInSpoken > 0 && i > 0) {
                                        const prevTargetWord = cleanWord(wordsRef.current[i - 1]);
                                        const prevSpokenWord = wordsToCheck[matchIndexInSpoken - 1];
                                        
                                        if (isFuzzyMatch(prevTargetWord, prevSpokenWord)) {
                                            bestJump = i + 1;
                                            break;
                                        } else {
                                            continue;
                                        }
                                    } else {
                                        continue;
                                    }
                                } else {
                                    bestJump = i + 1;
                                    if (matchIndexInSpoken === wordsToCheck.length - 1) {
                                        break;
                                    }
                                }
                            }
                        }
                        return Math.max(currentIndex, bestJump);
                    });
                };

                recognitionRef.current = recognition;
                return () => recognitionRef.current?.stop();
            }, [isPlaying, detectedLang]); // הוספנו תלות בשפה כדי שיאתחל את המיקרופון בהתאם

            useEffect(() => {
                if (isPlaying) {
                    setCurrentWordIndex(0);
                    lastSpeechRef.current = ''; 
                    try { recognitionRef.current?.start(); } catch(e) {}
                } else {
                    try { recognitionRef.current?.stop(); } catch(e) {}
                }
            }, [isPlaying]);

            useEffect(() => {
                if (isPlaying && containerRef.current) {
                    const scrollTargetIndex = Math.min(currentWordIndex + 5, wordsRef.current.length - 1);
                    const activeElement = document.getElementById(`word-${scrollTargetIndex}`);
                    if (activeElement) {
                        activeElement.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'nearest' });
                    }
                }
            }, [currentWordIndex, isPlaying]);

            const displayTransform = `${mirrorMode ? 'scaleX(-1)' : ''} ${flipVertical ? 'scaleY(-1)' : ''}`.trim() || 'none';

            return (
                <div className="flex flex-col md:flex-row h-screen bg-gray-950 text-white font-sans overflow-hidden">
                    
                    {/* תפריט צד */}
                    <div className={`w-full md:w-80 shrink-0 h-full overflow-y-auto hide-scrollbar bg-gray-900 border-b md:border-b-0 md:border-l border-gray-800 p-6 flex flex-col gap-6 transition-transform duration-300 z-10 ${isPlaying ? '-translate-y-full md:translate-y-0 md:translate-x-full hidden' : ''}`}>
                        <div className="flex items-center gap-3 border-b border-gray-800 pb-4 shrink-0">
                            <IconSettings />
                            <h1 className="text-xl font-bold">Vibe Prompter</h1>
                        </div>

                        {supportError && <div className="bg-red-900/50 text-red-400 p-3 rounded-md text-sm">{supportError}</div>}

                        <div className="flex flex-col gap-2 shrink-0">
                            <label className="text-sm text-gray-400 font-semibold flex justify-between items-end">
                                <span>הזן טקסט:</span>
                                {/* חיווי שפה מזוהה */}
                                <span className="text-xs flex items-center gap-1 bg-gray-800 px-2 py-1 rounded text-gray-300">
                                    <IconGlobe />
                                    {detectedLang === 'he' ? 'עברית' : 'English'}
                                </span>
                            </label>
                            <textarea 
                                value={text} onChange={(e) => setText(e.target.value)}
                                className="w-full h-32 bg-gray-800 border border-gray-700 rounded-md p-3 text-sm focus:outline-none focus:border-blue-500 resize-none"
                                dir={detectedLang === 'he' ? 'rtl' : 'ltr'}
                            />
                        </div>

                        <div className="flex flex-col gap-2 shrink-0">
                            <label className="text-sm text-gray-400 font-semibold flex justify-between">
                                <span>גודל טקסט</span><span>{fontSize}px</span>
                            </label>
                            <input type="range" min="24" max="100" value={fontSize} onChange={(e) => setFontSize(Number(e.target.value))} className="w-full accent-blue-500"/>
                        </div>

                        <div className="flex flex-col gap-2 shrink-0">
                            <label className="text-sm text-gray-400 font-semibold flex justify-between">
                                <span>שוליים (Padding)</span><span>{padding}%</span>
                            </label>
                            <input type="range" min="0" max="40" value={padding} onChange={(e) => setPadding(Number(e.target.value))} className="w-full accent-blue-500"/>
                        </div>

                        <div className="flex flex-col gap-2 shrink-0">
                            <label className="text-sm text-gray-400 font-semibold">יישור טקסט</label>
                            <div className="flex gap-2">
                                <button onClick={() => setAlignment('right')} className={`flex-1 p-2 rounded ${alignment === 'right' ? 'bg-blue-600' : 'bg-gray-800'}`}>ימין</button>
                                <button onClick={() => setAlignment('center')} className={`flex-1 p-2 rounded ${alignment === 'center' ? 'bg-blue-600' : 'bg-gray-800'}`}>מרכז</button>
                                <button onClick={() => setAlignment('left')} className={`flex-1 p-2 rounded ${alignment === 'left' ? 'bg-blue-600' : 'bg-gray-800'}`}>שמאל</button>
                            </div>
                        </div>

                        <div className="flex flex-col gap-2 shrink-0">
                            <label className="text-sm text-gray-400 font-semibold">טלפרומפטר פיזי</label>
                            <div className="flex gap-2">
                                <button onClick={() => setMirrorMode(!mirrorMode)} className={`flex-1 p-2 rounded-md transition-colors ${mirrorMode ? 'bg-indigo-600' : 'bg-gray-800'}`}>היפוך אופקי</button>
                                <button onClick={() => setFlipVertical(!flipVertical)} className={`flex-1 p-2 rounded-md transition-colors ${flipVertical ? 'bg-indigo-600' : 'bg-gray-800'}`}>היפוך אנכי</button>
                            </div>
                        </div>

                        <div className="mt-auto shrink-0 pt-4 pb-8 md:pb-0">
                            <button onClick={() => setIsPlaying(true)} disabled={!!supportError} className="w-full bg-blue-600 hover:bg-blue-500 disabled:bg-gray-600 text-white font-bold py-4 rounded-lg flex items-center justify-center gap-2 shadow-lg">
                                <IconPlay /> {detectedLang === 'he' ? 'התחל קריאה' : 'Start Reading'}
                            </button>
                        </div>
                    </div>

                    {/* אזור התצוגה של הטלפרומפטר */}
                    <div className="flex-1 relative flex flex-col items-center bg-black h-full" style={{ transform: displayTransform }}>
                        {isPlaying && (
                            <div className="absolute top-4 right-4 z-50 flex gap-2" style={{ transform: displayTransform }}>
                                <button onClick={() => setIsPlaying(false)} className="bg-red-600/80 text-white p-3 rounded-full flex items-center gap-2 shadow-lg">
                                    <IconStop /> <span className="font-bold hidden md:inline">עצור</span>
                                </button>
                                <div className={`flex items-center gap-2 px-3 py-2 rounded-full font-semibold shadow-lg ${isListening ? 'bg-green-500/20 text-green-400' : 'bg-gray-800/80 text-gray-400'}`}>
                                    {isListening ? <><IconMic /> <span className="hidden md:inline">מאזין...</span></> : <><IconMicOff /> <span className="hidden md:inline">כבוי</span></>}
                                </div>
                            </div>
                        )}

                        <div ref={containerRef} className="w-full h-full overflow-y-auto scroll-smooth hide-scrollbar" style={{ paddingLeft: `${padding}%`, paddingRight: `${padding}%`, paddingTop: '50vh', paddingBottom: '50vh' }}>
                            {/* שינוי כיוון התצוגה (RTL/LTR) לפי השפה המזוהה */}
                            <div style={{ fontSize: `${fontSize}px`, textAlign: alignment, lineHeight: '1.6', direction: detectedLang === 'he' ? 'rtl' : 'ltr' }} className="max-w-5xl mx-auto">
                                {words.map((word, index) => {
                                    if (word === '\n') return <br key={`br-${index}`} />;
                                    
                                    const isPast = index < currentWordIndex;
                                    
                                    return (
                                        <span 
                                            key={`word-${index}`} 
                                            id={`word-${index}`} 
                                            className={`inline-block mx-1 transition-colors duration-300 ${
                                                isPlaying 
                                                    ? (isPast ? 'text-green-400' : 'text-white font-bold') 
                                                    : 'text-white font-bold'
                                            }`}
                                        >
                                            {word}
                                        </span>
                                    );
                                })}
                            </div>
                        </div>
                        
                        {/* קו עזר למרכז הקריאה - עדין מאוד */}
                        {isPlaying && <div className="absolute top-1/2 left-0 w-full h-1 bg-gradient-to-r from-transparent via-blue-500/20 to-transparent pointer-events-none transform -translate-y-1/2"></div>}
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


